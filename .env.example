# ── EventIQ Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in the values

# ── Application ──────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# ── MongoDB ──────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongo:27017/eventbooking

# ── Redis (distributed seat locking) ────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── ML Recommendation Service ───────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8000
ML_API_KEY=your_ml_api_key_here

# ── AWS S3 (profile photo uploads) ──────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
